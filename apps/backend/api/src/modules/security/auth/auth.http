### Signup
POST {{host}}/auth/signup
Content-Type: {{contentType}}

{
  "username": "rsantamaria",
  "password": "RSFutbol2001@",
  "firstName": "Raul",
  "firstLastName": "Santamaria",
  "email": "rsantamariao@hospitalsantamaria.com.ec",
  "phoneNumber": "+593969883869",
  "gender": "male",
  "roles": ["admin"]
}

### Log in
POST {{host}}/auth/login
Content-Type: {{contentType}}

{
  "username": "rsantamaria",
  "password": "RSFutbol2001@"
}

### Logout
GET {{host}}/auth/logout
Authorization: Bearer {{at_token}}

### Profile
GET {{host}}/auth/profile
Authorization: Bearer {{at_token}}

### Refresh
GET {{host}}/auth/refresh
Authorization: Bearer {{rt_token}}

### Signup Integration Token
POST {{host}}/auth/signup/integration
Authorization: Bearer {{at_token}}
Content-Type: {{contentType}}

{
  "name": "raul",
  "description": "test",
  "functionality": "dev"
}

### Logout Integration Token
POST {{host}}/auth/logout/integration
Authorization: Bearer {{at_token}}
Content-Type: {{contentType}}

{
  "token": "<integration-token>"
}

### Generate PIN
POST {{host}}/auth/pin/generate
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "purpose": "email_verification",
  "target": "example@example.com"
}

### Validate PIN
POST {{host}}/auth/pin/validate
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "purpose": "email_verification",
  "target": "example@example.com",
  "code": 123456
}

### Forgot Password (request reset link)
POST {{host}}/auth/password/forgot
Content-Type: {{contentType}}

{
  "email": "rsantamariao@hospitalsantamaria.com.ec"
}

### Reset Password (consume token from emailed link fragment)
POST {{host}}/auth/password/reset
Content-Type: {{contentType}}

{
  "token": "<paste-token-from-reset-link-fragment>",
  "newPassword": "NewPassw0rd@2026"
}

### Recover Username (email the username)
POST {{host}}/auth/username/recover
Content-Type: {{contentType}}

{
  "email": "rsantamariao@hospitalsantamaria.com.ec"
}
