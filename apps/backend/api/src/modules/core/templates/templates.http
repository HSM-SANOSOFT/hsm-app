### Get Template
# Response shape: { data: { template: {..., metadata: {...}|null}, baseTemplate: {...}|null } }
GET {{host}}/templates/81813161-0010-596b-abe2-012f2bd3588c
content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

### Create EMAIL_EXTERNAL Template
POST {{host}}/templates
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "category": "EMAIL_EXTERNAL",
  "name": "welcome_email",
  "description": "Correo de bienvenida",
  "isActive": true,
  "schema": {
    "patientName": "string",
    "appointmentDate": "string?"
  },
  "content": "<p>Hola [patientName]</p>",
  "baseTemplateId": "123e4567-e89b-12d3-a456-426614174000",
  "email": {
    "subject": "Bienvenido a HSM",
    "fromEmail": "no-reply@hsm.org",
    "fromName": "HSM",
    "hasAttachment": false
  }
}

### Create SMS_INTERNAL Template
POST {{host}}/templates
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "category": "SMS_INTERNAL",
  "name": "sms_welcome",
  "description": "SMS de bienvenida",
  "isActive": true,
  "schema": {
    "patientName": "string",
    "appointmentDate": "string"
  },
  "content": "Hola [patientName], recordatorio: cita el [appointmentDate].",
  "baseTemplateId": "123e4567-e89b-12d3-a456-426614174000",
  "sms": {
    "provider": "twilio",
    "templateName": "welcome_sms",
    "from": "+15005550006"
  }
}

### Create BASE Template
POST {{host}}/templates
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "category": "BASE",
  "name": "email_layout",
  "description": "Base layout para emails",
  "isActive": true,
  "schema": {
    "body": "string"
  },
  "content": "<!doctype html><html><body>[[[body]]]</body></html>"
}

### Update Template
PUT {{host}}/templates/123e4567-e89b-12d3-a456-426614174000
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "description": "Descripción actualizada",
  "isActive": true
}

### Delete Template
DELETE {{host}}/templates/123e4567-e89b-12d3-a456-426614174000
Authorization: Bearer {{at_token}}

### Validate Template
POST {{host}}/templates/validate
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "identifier": "welcome_email",
  "data": {
    "patientName": "Ada Lovelace"
  }
}

### Draft Render (no base)
# Response shape: { data: { html: "..." } }
POST {{host}}/templates/draft-render
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "content": "<p>Hola {{patientName}}</p>",
  "sampleData": {
    "patientName": "Ada Lovelace"
  }
}

### Draft Render (with base composition)
POST {{host}}/templates/draft-render
Content-Type: {{contentType}}
Authorization: Bearer {{at_token}}

{
  "content": "<p>Hola {{patientName}}</p>",
  "baseTemplateId": "123e4567-e89b-12d3-a456-426614174000",
  "sampleData": {
    "patientName": "Ada Lovelace"
  }
}

### List all templates
GET {{host}}/templates
Authorization: Bearer {{at_token}}

### List templates by category (BASE for base-template selector)
GET {{host}}/templates?category=BASE
Authorization: Bearer {{at_token}}

### List DOCS templates (document generation picker)
GET {{host}}/templates?category=DOCS
Authorization: Bearer {{at_token}}
